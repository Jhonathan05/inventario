generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Catalogo {
  id          Int      @id @default(autoincrement())
  dominio     String
  valor       String
  descripcion String?
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  @@unique([dominio, valor])
  @@map("catalogos")
}

model Categoria {
  id      Int      @id @default(autoincrement())
  nombre  String   @unique
  icono   String?
  activos Activo[]

  @@map("categorias")
}

model Activo {
  id                 Int          @id @default(autoincrement())
  placa              String       @unique
  serial             String?
  marca              String
  modelo             String
  descripcion        String?
  estado             EstadoActivo @default(DISPONIBLE)
  categoriaId        Int?
  color              String?
  ubicacion          String?
  fechaCompra        DateTime?
  valorCompra        Decimal?
  garantiaHasta      DateTime?
  observaciones      String?
  imagen             String?
  empresaPropietaria String?      @default("FEDERACION")
  dependencia        String?      @default("SUCURSAL IBAGUE")
  fuenteRecurso      String?
  tipoRecurso        String?
  tipoControl        String?      @default("CONTROLADO")
  estadoOperativo    String?      @default("EN OPERACIÓN")
  razonEstado        String?      @default("DISPONIBLE")
  empresaFuncionario String?      @default("FEDERACION")
  tipoPersonal       String?
  cedulaFuncionario  String?
  shortname          String?
  nombreFuncionario  String?
  departamento       String?      @default("TOLIMA")
  ciudad             String?      @default("IBAGUE")
  cargo              String?
  area               String?
  tipo               String?
  nombreEquipo       String?
  procesador         String?
  memoriaRam         String?
  discoDuro          String?
  sistemaOperativo   String?
  creadoEn           DateTime     @default(now())
  actualizadoEn      DateTime     @updatedAt
  tiempoUso          String?
  tipoPropietario    String?
  checklist          String?
  ordenRemision      String?
  categoria          Categoria?   @relation(fields: [categoriaId], references: [id])
  asignaciones       Asignacion[]
  documentos         Documento[]
  hojaVida           HojaVida[]
  tickets            Ticket[]

  @@map("activos")
}

model Funcionario {
  id                 Int          @id @default(autoincrement())
  nombre             String
  cedula             String       @unique
  codigoPersonal     String?      @unique
  cargo              String?
  area               String?
  email              String?
  telefono           String?
  activo             Boolean      @default(true)
  shortname          String?
  vinculacion        String?
  empresaFuncionario String?
  proyecto           String?
  departamento       String?
  ciudad             String?
  seccional          String?
  municipio          String?
  ubicacion          String?
  piso               String?
  creadoEn           DateTime     @default(now())
  actas              Acta[]
  asignaciones       Asignacion[]
  tickets            Ticket[]

  @@map("funcionarios")
}

model Asignacion {
  id            Int            @id @default(autoincrement())
  activoId      Int
  funcionarioId Int
  fechaInicio   DateTime       @default(now())
  fechaFin      DateTime?
  tipo          TipoMovimiento
  observaciones String?
  realizadoPor  String?
  activo        Activo         @relation(fields: [activoId], references: [id])
  funcionario   Funcionario    @relation(fields: [funcionarioId], references: [id])
  documentos    Documento[]

  @@map("asignaciones")
}

model HojaVida {
  id                   Int                 @id @default(autoincrement())
  activoId             Int
  tipo                 TipoServicio
  descripcion          String
  tecnico              String?
  costo                Decimal?
  fecha                DateTime            @default(now())
  proximoMantenimiento DateTime?
  registradoPor        String?
  casoAranda           String?
  estado               EstadoMantenimiento @default(EN_PROCESO)
  diagnostico          String?
  responsableId        Int?
  documentos           Documento[]
  activo               Activo              @relation(fields: [activoId], references: [id])
  responsable          Usuario?            @relation("ResponsableTicket", fields: [responsableId], references: [id])
  ticketId             Int?
  ticket               Ticket?             @relation(fields: [ticketId], references: [id])
  trazas               TrazaHojaVida[]

  @@map("hoja_vida")
}

model TrazaHojaVida {
  id             Int                  @id @default(autoincrement())
  hojaVidaId     Int
  estadoAnterior EstadoMantenimiento?
  estadoNuevo    EstadoMantenimiento
  observacion    String
  fecha          DateTime             @default(now())
  usuarioId      Int?
  hojaVida       HojaVida             @relation(fields: [hojaVidaId], references: [id])
  usuario        Usuario?             @relation(fields: [usuarioId], references: [id])

  @@map("trazas_hoja_vida")
}

model Documento {
  id            Int          @id @default(autoincrement())
  nombre        String
  nombreArchivo String
  ruta          String
  tipo          String
  tamano        Int?
  activoId      Int?
  asignacionId  Int?
  hojaVidaId    Int?
  ticketId      Int?
  trazaTicketId Int?
  creadoEn      DateTime     @default(now())
  activo        Activo?      @relation(fields: [activoId], references: [id])
  asignacion    Asignacion?  @relation(fields: [asignacionId], references: [id])
  hojaVida      HojaVida?    @relation(fields: [hojaVidaId], references: [id])
  ticket        Ticket?      @relation(fields: [ticketId], references: [id])
  trazaTicket   TrazaTicket? @relation(fields: [trazaTicketId], references: [id])

  @@map("documentos")
}

model Usuario {
  id                      Int             @id @default(autoincrement())
  nombre                  String
  email                   String          @unique
  password                String
  rol                     Rol             @default(TECNICO)
  activo                  Boolean         @default(true)
  creadoEn                DateTime        @default(now())
  actualizadoEn           DateTime        @updatedAt
  actasCreadas            Acta[]
  asignacionesResponsable HojaVida[]      @relation("ResponsableTicket")
  ticketsAsignados        Ticket[]        @relation("TicketsAsignados")
  ticketsCreados          Ticket[]        @relation("TicketsCreados")
  trazas                  TrazaHojaVida[]
  trazasTicket            TrazaTicket[]

  @@map("usuarios")
}

model PerfilReporte {
  id            Int      @id @default(autoincrement())
  nombre        String   @unique
  descripcion   String?
  tipoReporte   String
  columnas      Json
  esPredefinido Boolean  @default(false)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("perfiles_reporte")
}

model Acta {
  id            Int          @id @default(autoincrement())
  tipo          String
  fecha         DateTime     @default(now())
  archivoUrl    String?
  observaciones String?
  creadoPorId   Int
  funcionarioId Int?
  detalles      Json
  creadoPor     Usuario      @relation(fields: [creadoPorId], references: [id])
  funcionario   Funcionario? @relation(fields: [funcionarioId], references: [id])

  @@map("actas")
}

model Ticket {
  id            Int             @id @default(autoincrement())
  titulo        String
  descripcion   String
  estado        EstadoTicket    @default(CREADO)
  prioridad     PrioridadTicket @default(MEDIA)
  tipo          TipoTicket      @default(REQUERIMIENTO)
  funcionarioId Int
  activoId      Int?
  asignadoAId   Int?
  creadoPorId   Int
  creadoEn      DateTime        @default(now())
  actualizadoEn DateTime        @updatedAt
  cerradoEn     DateTime?
  adjuntos      Documento[]
  activo        Activo?         @relation(fields: [activoId], references: [id])
  asignadoA     Usuario?        @relation("TicketsAsignados", fields: [asignadoAId], references: [id])
  creadoPor     Usuario         @relation("TicketsCreados", fields: [creadoPorId], references: [id])
  funcionario   Funcionario     @relation(fields: [funcionarioId], references: [id])
  trazas        TrazaTicket[]
  hojaVida      HojaVida[]

  @@map("tickets")
}

model TrazaTicket {
  id             Int             @id @default(autoincrement())
  ticketId       Int
  tipoTraza      TipoTrazaTicket @default(COMENTARIO)
  comentario     String
  estadoAnterior EstadoTicket?
  estadoNuevo    EstadoTicket?
  creadoPorId    Int
  creadoEn       DateTime        @default(now())
  adjuntos       Documento[]
  creadoPor      Usuario         @relation(fields: [creadoPorId], references: [id])
  ticket         Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("trazas_ticket")
}

enum EstadoActivo {
  DISPONIBLE
  ASIGNADO
  EN_MANTENIMIENTO
  DADO_DE_BAJA
}

enum TipoMovimiento {
  ASIGNACION
  TRASLADO
  DEVOLUCION
}

enum TipoServicio {
  MANTENIMIENTO
  REPARACION
  SUMINISTRO
  INSPECCION
  ACTUALIZACION
  GARANTIA
}

enum EstadoMantenimiento {
  CREADO
  EN_PROCESO
  SUSPENDIDO
  FINALIZADO
  CERRADO
  ESPERA_SUMINISTRO
  PROCESO_GARANTIA
}

enum Rol {
  ADMIN
  TECNICO
  CONSULTA
}

enum EstadoTicket {
  CREADO
  EN_CURSO
  SIN_RESPUESTA
  COMPLETADO
}

enum PrioridadTicket {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum TipoTicket {
  INCIDENTE
  REQUERIMIENTO
}

enum TipoTrazaTicket {
  CREACION
  COMENTARIO
  CAMBIO_ESTADO
  ASIGNACION
}
